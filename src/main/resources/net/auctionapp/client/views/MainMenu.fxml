<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1024.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.controllers.MainMenuController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1024.0" style="-fx-background-color: #3bb3c3;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
            </padding>
            <children>
                <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="Auction Dashboard" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleLogout" style="-fx-background-color: white; -fx-text-fill: #3bb3c3; -fx-background-radius: 20px; -fx-padding: 8px 25px; -fx-font-weight: bold; -fx-cursor: hand;" text="Logout" />
            </children>
        </HBox>
    </top>

    <center>
        <HBox spacing="40.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <VBox alignment="TOP_LEFT" prefWidth="350.0" spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #666666;" text="Welcome" />
                        <Label fx:id="usernameLabel" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Guest" wrapText="true" />
                        <Label fx:id="roleLabel" style="-fx-font-size: 14px; -fx-text-fill: #666666;" text="Role: BIDDER" />
                        <Label fx:id="balanceLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3bb3c3;" text="Balance: $0.00" />
                        <Label style="-fx-font-size: 13px; -fx-text-fill: #888888;" text="Manage your auctions and bidding activities from this dashboard." wrapText="true" />
                    </children>
                </VBox>

                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Quick Actions" />
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #666666;" text="Choose where you want to go next." />

                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleBrowseAuctions" prefHeight="48.0" style="-fx-background-color: #3bb3c3; -fx-text-fill: white; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Browse Auctions" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSellItem" prefHeight="48.0" style="-fx-background-color: #3bb3c3; -fx-text-fill: white; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Sell Item" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMyBids" prefHeight="48.0" style="-fx-background-color: #ffffff; -fx-text-fill: #3bb3c3; -fx-border-color: #3bb3c3; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="My Bids" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleMyListings" prefHeight="48.0" style="-fx-background-color: #ffffff; -fx-text-fill: #3bb3c3; -fx-border-color: #3bb3c3; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="My Listings" />
                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleSettings" prefHeight="48.0" style="-fx-background-color: #ffffff; -fx-text-fill: #3bb3c3; -fx-border-color: #3bb3c3; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Settings" />

                        <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-text-fill: #666666;" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </center>
</BorderPane>
