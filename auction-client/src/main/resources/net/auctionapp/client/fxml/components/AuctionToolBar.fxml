<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="auction-toolbar" stylesheets="@../../styles/ui-states.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.components.AuctionToolBarController">
    <children>
        <Label styleClass="auction-toolbar-label" text="Search auctions:" />
        <TextField fx:id="searchField" prefHeight="35.0" prefWidth="280.0" styleClass="auction-toolbar-search" />
        <ComboBox fx:id="statusFilterComboBox" prefHeight="35.0" prefWidth="170.0" promptText="Status" styleClass="auction-toolbar-filter" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="refreshButton" mnemonicParsing="false" prefHeight="35.0" prefWidth="100.0" styleClass="auction-toolbar-refresh" text="Refresh" />
    </children>
    <padding>
        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
    </padding>
</HBox>
