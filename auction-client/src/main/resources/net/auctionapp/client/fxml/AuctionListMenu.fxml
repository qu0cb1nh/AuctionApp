<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="634.0" prefWidth="967.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.AuctionListMenuController">
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <children>
                <fx:include fx:id="appHeader" source="components/Header.fxml" />
                <HBox alignment="CENTER_LEFT" spacing="14.0" style="-fx-background-color: #3bb3d1;">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="Find live auctions:" />
                        <TextField fx:id="searchField" onKeyReleased="#handleFilterChanged" prefHeight="35.0" prefWidth="250.0" promptText="Search for products..." style="-fx-background-radius: 15;" />
                        <ComboBox fx:id="statusFilterComboBox" onAction="#handleFilterChanged" prefHeight="35.0" prefWidth="150.0" promptText="Filter status" style="-fx-background-radius: 10;" />
                        <ComboBox fx:id="sortComboBox" onAction="#handleFilterChanged" prefHeight="35.0" prefWidth="180.0" promptText="Sort by" style="-fx-background-radius: 10;" />
                        <Button mnemonicParsing="false" onAction="#handleClearFilters" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #e7f8fb; -fx-text-fill: #217b93; -fx-background-radius: 10; -fx-font-weight: bold;" text="Clear Filters" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: white; -fx-text-fill: #3bb3d1; -fx-background-radius: 10; -fx-font-weight: bold;" text="Refresh" />
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #e9ecef;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="10.0" style="-fx-padding: 20;">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Auction Marketplace" />
                        <Label fx:id="listStatusLabel" style="-fx-text-fill: #3f5569; -fx-font-size: 12px;" text="Loading auctions..." />
                        <VBox fx:id="auctionFlowPane" spacing="8.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
