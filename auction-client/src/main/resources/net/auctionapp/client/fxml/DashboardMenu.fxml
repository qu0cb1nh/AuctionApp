<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="634.0" prefWidth="967.0" style="-fx-background-color: #f7f7f5;" stylesheets="@../styles/ui-states.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.DashboardMenuController">
   <center>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="436.0" prefWidth="420.0" spacing="14.0" BorderPane.alignment="CENTER">
         <children>
                  <Label fx:id="usernameLabel" alignment="CENTER" contentDisplay="CENTER" style="-fx-font-size: 36px; -fx-font-weight: 600; -fx-text-fill: #2f3437;" text="Welcome back, Guest" textAlignment="CENTER" wrapText="true">
               <VBox.margin>
                  <Insets bottom="30.0" />
               </VBox.margin>
            </Label>

                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleBrowseAuctions" prefHeight="67.0" prefWidth="330.0" style="-fx-background-color: #8F5B45; -fx-text-fill: white; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: 700; -fx-cursor: hand;" text="Browse auctions">
               <graphic>
                  <ImageView fitHeight="33.0" fitWidth="312.0" pickOnBounds="true" preserveRatio="true" translateX="-2.0">
                     <image>
                        <Image url="@../images/BrowseAuction.png" />
                     </image>
                  </ImageView>
               </graphic>
               <VBox.margin>
                  <Insets bottom="25.0" top="4.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="14.0" top="14.0" />
               </padding>
            </Button>
                  <Button fx:id="sellItemButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleSellItem" prefHeight="67.0" prefWidth="330.0" style="-fx-background-color: #F8F3EF; -fx-border-radius: 12px; -fx-border-color: #D8C8BE; -fx-text-fill: #2f3437; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: 700; -fx-cursor: hand;" text="Create an auction">
               <graphic>
                  <ImageView fitHeight="36.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/Sell.png" />
                     </image>
                  </ImageView>
               </graphic>
               <VBox.margin>
                  <Insets top="0.0" />
               </VBox.margin>
                <padding>
                    <Insets bottom="14.0" top="14.0" />
                 </padding>
              </Button>
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
         <BorderPane.margin>
            <Insets bottom="40.0" />
         </BorderPane.margin>
      </VBox>
   </center>
   <top>
        <fx:include fx:id="appHeader" source="components/Header.fxml" />
   </top>
</BorderPane>
