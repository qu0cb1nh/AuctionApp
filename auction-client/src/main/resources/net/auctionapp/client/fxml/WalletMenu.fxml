<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="634.0" prefWidth="967.0" style="-fx-background-color: #f4f4f4;" stylesheets="@../styles/ui-states.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.WalletMenuController">
    <top>
        <fx:include fx:id="appHeader" source="components/Header.fxml" />
    </top>

    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="36.0" left="42.0" right="42.0" top="38.0" />
            </padding>
            <children>
                <HBox alignment="CENTER" maxWidth="760.0" spacing="12.0">
                    <children>
                        <VBox alignment="CENTER" minHeight="125.0" prefHeight="125.0" prefWidth="245.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Total Balance" />
                                <TextField fx:id="totalBalanceField" alignment="CENTER" editable="false" focusTraversable="false" prefHeight="48.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #153e5c; -fx-font-size: 26px; -fx-font-weight: bold;" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" minHeight="125.0" prefHeight="125.0" prefWidth="245.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Available Balance" />
                                <TextField fx:id="availableBalanceField" alignment="CENTER" editable="false" focusTraversable="false" prefHeight="48.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #3bb3c3; -fx-font-size: 26px; -fx-font-weight: bold;" text="0" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" minHeight="125.0" prefHeight="125.0" prefWidth="245.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 3);">
                            <children>
                                <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="On Hold for Bids" />
                                <TextField fx:id="pendingBalanceField" alignment="CENTER" editable="false" focusTraversable="false" prefHeight="48.0" prefWidth="220.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-text-fill: #d97706; -fx-font-size: 26px; -fx-font-weight: bold;" text="0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox maxWidth="640.0" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Deposit" />
                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                            <children>
                                <TextField fx:id="depositField" prefHeight="42.0" prefWidth="430.0" promptText="Enter amount" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-radius: 8px; -fx-border-color: #b6dfe7; -fx-font-size: 14px;" />
                                <Button fx:id="depositButton" mnemonicParsing="false" onAction="#handleDeposit" prefHeight="42.0" prefWidth="145.0" style="-fx-background-color: #3bb3c3; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Deposit" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox maxWidth="640.0" spacing="10.0">
                    <children>
                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Withdraw" />
                        <HBox alignment="CENTER_LEFT" spacing="14.0">
                            <children>
                                <TextField fx:id="withdrawField" prefHeight="42.0" prefWidth="430.0" promptText="Enter amount" style="-fx-background-color: white; -fx-background-radius: 8px; -fx-border-radius: 8px; -fx-border-color: #b6dfe7; -fx-font-size: 14px;" />
                                <Button fx:id="withdrawButton" mnemonicParsing="false" onAction="#handleWithdraw" prefHeight="42.0" prefWidth="145.0" style="-fx-background-color: #3bb3c3; -fx-text-fill: white; -fx-background-radius: 8px; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Withdraw" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
            </children>
        </VBox>
    </center>
</BorderPane>
