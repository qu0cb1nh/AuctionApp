<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="634.0" prefWidth="967.0" stylesheets="@../styles/ui-states.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.AdminPanelMenuController">
    <top>
        <fx:include fx:id="appHeader" source="components/Header.fxml" />
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f0f3f7;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="12.0" style="-fx-padding: 20;">
                    <children>
                        <Label fx:id="statusLabel" styleClass="admin-status" text="Ready." />
                        <HBox alignment="CENTER_LEFT" prefHeight="40.0" spacing="8.0">
                            <children>
                                <Label fx:id="userManagementNavLabel" minWidth="180.0" onMouseClicked="#handleShowUserManagement" prefWidth="180.0" styleClass="admin-nav-label" text="User Management" />
                                <Label fx:id="auctionManagementNavLabel" minWidth="230.0" onMouseClicked="#handleShowAuctionManagement" prefWidth="230.0" styleClass="admin-nav-label" text="Auction Management" />
                                <Region HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <Separator />
                        <StackPane prefHeight="470.0" HBox.hgrow="ALWAYS">
                            <children>
                                <VBox fx:id="userManagementPage" managed="false" minHeight="470.0" prefHeight="470.0" spacing="12.0" visible="false">
                                    <children>
                                        <TableView fx:id="usersTable" prefHeight="410.0">
                                            <columns>
                                                <TableColumn fx:id="userIdColumn" prefWidth="180.0" text="User ID" />
                                                <TableColumn fx:id="usernameColumn" prefWidth="180.0" text="Username" />
                                                <TableColumn fx:id="roleColumn" prefWidth="120.0" text="Role" />
                                                <TableColumn fx:id="bannedColumn" prefWidth="100.0" text="Banned" />
                                                <TableColumn fx:id="onlineColumn" prefWidth="100.0" text="Online" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="banButton" mnemonicParsing="false" onAction="#handleBanSelected" style="-fx-background-color: #c13c21; -fx-text-fill: white; -fx-font-weight: bold;" text="Ban Selected" />
                                                <Button fx:id="unbanButton" mnemonicParsing="false" onAction="#handleUnbanSelected" style="-fx-background-color: #1f8f4c; -fx-text-fill: white; -fx-font-weight: bold;" text="Unban Selected" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button mnemonicParsing="false" onAction="#handleRefreshUsers" style="-fx-background-color: #3bb3d1; -fx-text-fill: white; -fx-font-weight: bold;" text="Refresh Users" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox fx:id="auctionManagementPage" managed="false" minHeight="470.0" prefHeight="470.0" spacing="12.0" visible="false">
                                    <children>
                                        <TableView fx:id="auctionsTable" prefHeight="410.0">
                                            <columns>
                                                <TableColumn fx:id="auctionIdColumn" prefWidth="170.0" text="Auction ID" />
                                                <TableColumn fx:id="auctionTitleColumn" prefWidth="220.0" text="Title" />
                                                <TableColumn fx:id="auctionStatusColumn" prefWidth="120.0" text="Status" />
                                                <TableColumn fx:id="auctionCurrentPriceColumn" prefWidth="120.0" text="Current Price" />
                                                <TableColumn fx:id="auctionStartTimeColumn" prefWidth="150.0" text="Start Time" />
                                                <TableColumn fx:id="auctionEndTimeColumn" prefWidth="150.0" text="End Time" />
                                            </columns>
                                        </TableView>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="openAuctionButton" mnemonicParsing="false" onAction="#handleOpenAuction" style="-fx-background-color: #3bb3d1; -fx-text-fill: white; -fx-font-weight: bold;" text="Open Details" />
                                                <Button fx:id="manageAuctionButton" mnemonicParsing="false" onAction="#handleManageAuction" style="-fx-background-color: #153e5c; -fx-text-fill: white; -fx-font-weight: bold;" text="Manage Auction" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button mnemonicParsing="false" onAction="#handleRefreshAuctions" style="-fx-background-color: #3bb3d1; -fx-text-fill: white; -fx-font-weight: bold;" text="Refresh Auctions" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </children>
                    <padding>
                        <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
