<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="634.0" prefWidth="967.0" stylesheets="@../styles/ui-states.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.ui.controllers.MyActivityMenuController">
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <children>
                <fx:include fx:id="appHeader" source="components/Header.fxml" />
                <fx:include fx:id="auctionToolBar" source="components/AuctionToolBar.fxml" />
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #e9ecef;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="10.0" style="-fx-padding: 20;">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="My Activities" />
                        <Label fx:id="statusLabel" styleClass="activity-status" text="Loading activities..." />
                        <Label fx:id="summaryLabel" style="-fx-text-fill: #3f5569; -fx-font-size: 12px;" text="" />
                        <VBox fx:id="activityFlowPane" spacing="8.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
