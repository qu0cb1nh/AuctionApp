<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="634.0" prefWidth="967.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.controllers.MainMenuController">
   <center>
      <VBox alignment="BASELINE_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="500.0" prefWidth="450.0" BorderPane.alignment="CENTER">
         <children>
                  <Label fx:id="usernameLabel" alignment="CENTER" contentDisplay="CENTER" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Welcome back, Guest" textAlignment="CENTER" wrapText="true">
               <VBox.margin>
                  <Insets left="3.0" />
               </VBox.margin>
            </Label>

                        <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleBrowseAuctions" prefHeight="48.0" prefWidth="350.0" style="-fx-background-color: #3bb3c3; -fx-text-fill: white; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Browse Auctions">
               <graphic>
                  <ImageView fitHeight="36.0" fitWidth="49.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/BrowseAuction.png" />
                     </image>
                  </ImageView>
               </graphic>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="20.0" top="20.0" />
               </padding>
            </Button>
                  <Button maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleSellItem" prefHeight="48.0" prefWidth="350.0" style="-fx-background-color: #ffffff; -fx-border-radius: 12px; -fx-border-color: #3bb3c3; -fx-text-fill: #3bb3c3; -fx-background-radius: 12px; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;" text="Sell Item">
               <graphic>
                  <ImageView fitHeight="36.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/Sell.png" />
                     </image>
                  </ImageView>
               </graphic>
               <VBox.margin>
                  <Insets top="50.0" />
               </VBox.margin>
               <padding>
                   <Insets bottom="20.0" top="20.0" />
                </padding>
             </Button>
         </children>
      </VBox>
   </center>
   <top>
        <fx:include fx:id="appHeader" source="Header.fxml" />
   </top>
</BorderPane>
