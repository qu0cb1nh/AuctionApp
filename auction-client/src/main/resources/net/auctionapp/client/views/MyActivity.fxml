<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" prefHeight="634.0" prefWidth="967.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.controllers.MyActivityController">
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <children>
                <fx:include fx:id="appHeader" source="Header.fxml" />
                <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-background-color: #3bb3d1;">
                    <children>
                        <TextField fx:id="searchField" onKeyReleased="#handleFilterChanged" prefHeight="35.0" prefWidth="280.0" promptText="Search your bids and auctions..." style="-fx-background-radius: 15;" />
                        <ComboBox fx:id="statusFilterComboBox" onAction="#handleFilterChanged" prefHeight="35.0" prefWidth="170.0" promptText="Status" style="-fx-background-radius: 10;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleRefresh" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: white; -fx-text-fill: #3bb3d1; -fx-background-radius: 10; -fx-font-weight: bold;" text="Refresh" />
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #e9ecef;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="12.0" style="-fx-padding: 20;">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Your Bids" />
                        <FlowPane fx:id="bidActivityFlowPane" hgap="20.0" vgap="20.0" />
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #153e5c;" text="Your Auctions" />
                        <FlowPane fx:id="sellerActivityFlowPane" hgap="20.0" vgap="20.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <Label fx:id="statusLabel" style="-fx-padding: 8 24 12 24; -fx-text-fill: #3f5569; -fx-font-size: 12px; -fx-font-weight: bold;" text="Ready." />
    </bottom>
</BorderPane>
