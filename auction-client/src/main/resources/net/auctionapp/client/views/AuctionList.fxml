<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="634.0" prefWidth="967.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.auctionapp.client.controllers.AuctionListController">
    <top>
        <VBox spacing="0.0" BorderPane.alignment="CENTER">
            <children>
                <fx:include fx:id="appHeader" source="Header.fxml" />
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #3bb3d1;">
                    <children>
                        <TextField prefHeight="35.0" prefWidth="250.0" promptText="Search for products..." style="-fx-background-radius: 15;" />
                        <ComboBox prefHeight="35.0" prefWidth="150.0" promptText="Filter by..." style="-fx-background-radius: 10;" />
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="25.0" right="25.0" top="15.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #e9ecef;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="10.0" style="-fx-padding: 20;">
                    <children>
                        <Label fx:id="listStatusLabel" style="-fx-text-fill: #666666;" text="Loading auctions..." />
                        <FlowPane fx:id="auctionFlowPane" hgap="20.0" vgap="20.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
